# Per-cell benchmark reports, rendered SVGs, and raw agent traces are local
# reproduction artifacts, not committed; only the aggregate SVGs copied into
# assets/ are the tracked measurement record.
tests/benchmark/results/*.traces/
tests/benchmark/results/preflight.json
tests/benchmark/results/codex-*.json
tests/benchmark/results/claude-*.json

tests/benchmark/results/*.svg
tests/benchmark/results/svg/
tests/benchmark/results/png/
tests/benchmark/results/viewer/
tests/benchmark/results/.excluded/

# package README is copied from the root at build time
packages/graph/README.md

# Tarballs packed for release inspection. The published artifact is the one the
# registry serves; these are the copies the preflight opened to check it.
.release/
