{
  "name": "@samchon/graph",
  "version": "0.2.0",
  "description": "Language-server-backed code graph over MCP for statically typed compiled languages.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "samchon-graph": "lib/bin.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm --filter @samchon/graph-sitter build && rimraf lib && ttsc -p tsconfig.json && node build/copy-go-sidecar.mjs && node build/bundle-viewer.mjs && node -e \"require('node:fs').copyFileSync('../../README.md', 'README.md')\"",
    "prepublishOnly": "node build/copy-go-sidecar.mjs && node -e \"require('node:fs').copyFileSync('../../README.md', 'README.md')\""
  },
  "keywords": [
    "mcp",
    "lsp",
    "code-graph",
    "language-server",
    "static-analysis"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "README.md",
    "LICENSE",
    "lib",
    "sidecars",
    "src"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@samchon/graph-sitter": "workspace:*",
    "@typia/interface": "catalog:samchon",
    "@typia/mcp": "catalog:samchon",
    "typia": "catalog:samchon"
  },
  "devDependencies": {
    "@types/node": "catalog:utils",
    "@types/three": "^0.184.1",
    "esbuild": "catalog:bundler",
    "rimraf": "catalog:utils",
    "three": "^0.184.0",
    "three-forcegraph": "^1.43.4",
    "ttsc": "catalog:samchon",
    "typescript": "catalog:typescript"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/graph"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/graph/issues"
  },
  "homepage": "https://github.com/samchon/graph#readme"
}
