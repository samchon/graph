{
  "name": "@samchon/graph",
  "version": "0.1.0",
  "description": "Language-server-backed code graph over MCP for statically typed compiled languages.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "samchon-graph": "lib/bin.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && node node_modules/ttsc/lib/launcher/ttsc.js -p tsconfig.json",
    "test": "npm run build && node --disable-warning=ExperimentalWarning --experimental-transform-types test/src/index.ts",
    "coverage": "npm run build && c8 --reporter=text --reporter=lcov --check-coverage --lines 80 --functions 75 --branches 65 node --disable-warning=ExperimentalWarning --experimental-transform-types test/src/index.ts"
  },
  "keywords": [
    "mcp",
    "lsp",
    "code-graph",
    "language-server",
    "static-analysis"
  ],
  "files": [
    "README.md",
    "LICENSE",
    "lib",
    "src"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@typia/mcp": "13.0.0-rc.1",
    "typia": "13.0.0-rc.1"
  },
  "devDependencies": {
    "@nestia/e2e": "12.0.0-rc.2",
    "c8": "^10.1.3",
    "@types/node": "^22.18.0",
    "rimraf": "^6.0.1",
    "ttsc": "^0.16.12",
    "typescript": "7.0.1-rc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/graph"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/graph/issues"
  },
  "homepage": "https://github.com/samchon/graph#readme"
}
