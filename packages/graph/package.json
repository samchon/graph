{
  "name": "@samchon/graph",
  "version": "0.1.0",
  "description": "Language-server-backed code graph over MCP for statically typed compiled languages.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "samchon-graph": "lib/bin.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && node node_modules/ttsc/lib/launcher/ttsc.js -p tsconfig.json"
  },
  "keywords": [
    "mcp",
    "lsp",
    "code-graph",
    "language-server",
    "static-analysis"
  ],
  "files": [
    "README.md",
    "LICENSE",
    "lib",
    "src"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@typia/mcp": "catalog:samchon",
    "typia": "catalog:samchon"
  },
  "devDependencies": {
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils",
    "ttsc": "catalog:samchon",
    "typescript": "catalog:typescript"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/graph"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/graph/issues"
  },
  "homepage": "https://github.com/samchon/graph#readme"
}
