{
  "name": "@samchon/graph-sitter",
  "version": "0.2.0",
  "description": "Best-effort static syntax graph extraction for @samchon/graph.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
